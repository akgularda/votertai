{
  "name": "radiotedu-local-voting-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build && npm run dev:server",
    "dev:server": "tsx watch --env-file=.env src/server/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "start": "npm run build && tsx --env-file=.env src/server/index.ts",
    "dashboard": "tsx --env-file=.env src/cli/dashboard.ts",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run --config vitest.config.ts",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.5.13",
    "jsdom": "^25.0.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.10"
  }
}
